# ============================================================================
#  AI Mock Interview — configuration template
#
#  Copy this to .streamlit/secrets.toml and fill in real values.
#  On Streamlit Cloud, paste the same contents into Settings -> Secrets.
#
#  NEVER commit the real secrets.toml. It is in .gitignore — keep it that way.
# ============================================================================

# ---- REQUIRED ---------------------------------------------------------------

# Groq — powers question generation, answer scoring, resume parsing.
# Free key: https://console.groq.com
GROQ_API_KEY = "gsk_xxxxxxxxxxxxxxxxxxxxxxxx"

# Signs the login cookie so sessions survive a page refresh.
# Generate:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET = "replace-with-a-64-char-random-hex-string"

# Which account is the admin (gates the Admin Panel and Global Search).
ADMIN_EMAIL = "you@example.com"

# Supabase Postgres — permanent user storage.
# Supabase -> Settings -> Database -> Connection string -> Transaction pooler
[supabase]
host     = "aws-0-<region>.pooler.supabase.com"
port     = "6543"
user     = "postgres.<your-project-ref>"
password = "your-db-password"
dbname   = "postgres"


# ---- OPTIONAL ---------------------------------------------------------------

# Adzuna — live job listings in the Job Search Agent.
# Free key: https://developer.adzuna.com
ADZUNA_APP_ID  = ""
ADZUNA_APP_KEY = ""

# Serper — per-site job counts in Global Search (admin only).
# 2,500 free searches: https://serper.dev
SERPER_API_KEY = ""

# Alternative to Serper: Google Custom Search (100 searches/day free).
GOOGLE_CSE_KEY = ""
GOOGLE_CSE_CX  = ""
